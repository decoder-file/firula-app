{
  "expo": {
    "name": "Firula Mobile",
    "slug": "firula-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon-firula.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash/android/drawable-xxxhdpi/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#00C853"
    },
    "ios": {
      "supportsTablet": true,
      "splash": {
        "image": "./assets/splash/ios/SplashScreen.imageset/LaunchImage@3x.png",
        "resizeMode": "cover",
        "backgroundColor": "#00C853"
      },
      "bundleIdentifier": "com.loureiro-12.firula-mobile",
      "infoPlist": {
        "NSCameraUsageDescription": "Precisamos da camera para voce tirar e atualizar sua foto de perfil.",
        "NSPhotoLibraryUsageDescription": "Precisamos da sua galeria para voce escolher uma foto de perfil.",
        "NSPhotoLibraryAddUsageDescription": "Precisamos acessar a galeria para salvar e usar sua foto de perfil."
      }
    },
    "android": {
      "splash": {
        "image": "./assets/splash/android/drawable-xxxhdpi/splash.png",
        "resizeMode": "cover",
        "backgroundColor": "#00C853"
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-foreground-firula.png",
        "backgroundColor": "#1FBD58"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "cameraPermission": "Precisamos da camera para voce tirar e atualizar sua foto de perfil.",
          "photosPermission": "Precisamos da sua galeria para voce escolher uma foto de perfil."
        }
      ],
      "expo-web-browser"
    ],
    "scheme": "firula-mobile",
    "experiments": {
      "typedRoutes": true
    }
  }
}
