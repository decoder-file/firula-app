{
  "expo": {
    "name": "Firula Mobile",
    "slug": "firula-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon-firula.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash/android/drawable-xxxhdpi/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "splash": {
        "image": "./assets/splash/ios/SplashScreen.imageset/LaunchImage@3x.png",
        "resizeMode": "cover",
        "backgroundColor": "#ffffff"
      },
      "bundleIdentifier": "com.loureiro-12.firula-mobile"
    },
    "android": {
      "splash": {
        "image": "./assets/splash/android/drawable-xxxhdpi/splash.png",
        "resizeMode": "cover",
        "backgroundColor": "#ffffff"
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-foreground-firula.png",
        "backgroundColor": "#1FBD58"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "scheme": "firula-mobile",
    "experiments": {
      "typedRoutes": true
    }
  }
}
