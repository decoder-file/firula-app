{
  "expo": {
    "name": "Firula",
    "slug": "firula",
    "version": "1.0.4",
    "orientation": "portrait",
    "icon": "./assets/icon-firula.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash/android/drawable-xxxhdpi/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#00C853"
    },
    "ios": {
      "supportsTablet": true,
      "splash": {
        "image": "./assets/splash/ios/SplashScreen.imageset/LaunchImage@3x.png",
        "resizeMode": "cover",
        "backgroundColor": "#00C853"
      },
      "bundleIdentifier": "com.firulaapp.firula-app",
      "infoPlist": {
        "NSCameraUsageDescription": "Precisamos da camera para voce tirar e atualizar sua foto de perfil.",
        "NSPhotoLibraryUsageDescription": "Precisamos da sua galeria para voce escolher uma foto de perfil.",
        "NSPhotoLibraryAddUsageDescription": "Precisamos acessar a galeria para salvar e usar sua foto de perfil."
      },
      "appleTeamId": "G58V8BP6VH"
    },
    "android": {
      "splash": {
        "image": "./assets/splash/android/drawable-xxxhdpi/splash.png",
        "resizeMode": "cover",
        "backgroundColor": "#00C853"
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-foreground-firula.png",
        "backgroundColor": "#1FBD58"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.firulaapp"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "cameraPermission": "Precisamos da camera para voce tirar e atualizar sua foto de perfil.",
          "photosPermission": "Precisamos da sua galeria para voce escolher uma foto de perfil."
        }
      ],
      "expo-web-browser",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.664340745471-arlfoapbgtkn230b0jcljneurkni5185"
        }
      ],
      "expo-apple-authentication",
      "./plugins/withGoogleSignInPodfile",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon-firula.png",
          "color": "#00C853",
          "androidMode": "default"
        }
      ]
    ],
    "scheme": "firula-mobile",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "809a7ea8-d491-4ac3-9d13-8fc79d2d8b1d"
      }
    }
  }
}
